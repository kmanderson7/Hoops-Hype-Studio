{
  "//": "Helper config used to regenerate the .js mirrors that sit alongside .ts/.tsx in src/. Vite uses the .tsx via index.html → main.tsx, but committed .js mirrors track the tsc output so reviewers can see the JSX-stripped form. Run: pnpm exec tsc -p tsconfig.regen-mirrors.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "outDir": "./src",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false,
    "removeComments": false,
    "isolatedModules": false,
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__/**"
  ]
}
