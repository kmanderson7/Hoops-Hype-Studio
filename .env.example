# Copy to .env and set values (or set in Netlify UI / GitHub secrets)
STORAGE_BUCKET=your-bucket
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# GPU worker (Modal) bridge
GPU_WORKER_BASE_URL=
GPU_WORKER_TOKEN=

# AI provider (OpenAI) — optional; enables GPT-4o highlight classification
# When set in the Modal secret `hoops-hype-studio`, the worker uses
# `_classify_action_openai` and falls back to YOLO+heuristic on any error.
OPENAI_API_KEY=

# Music provider (Pixabay) — get a free key at pixabay.com/api/docs
MUSIC_API_KEY=
MUSIC_API_BASE_URL=https://pixabay.com/api

# Redis (Upstash) for job/progress + rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability
LOGTAIL_TOKEN=
SENTRY_DSN=

# Edge security
EDGE_HMAC_SECRET=
RATE_LIMIT_TOKENS=120
RATE_LIMIT_WINDOW_SEC=60

# Retention policy (days)
RETENTION_DAYS=7

WEB_ORIGIN=http://localhost:5173
