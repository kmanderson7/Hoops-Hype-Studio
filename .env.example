# Copy to .env and set values (or set in Netlify UI / GitHub secrets).
# After deploy, hit POST /.netlify/functions/configHealth (or click
# "System Health" in the Export panel) to verify which vars are set.

# === REQUIRED for renders to succeed ===

# Storage (Cloudflare R2; S3-API-compatible). Modal uploads finished mp4s here; the API
# re-signs presigned URLs from these creds in finalizeExport.
STORAGE_BUCKET=your-bucket
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# GPU worker (Modal) bridge. Without these, runRender-background never kicks
# off — startRenderJob writes a `no_worker_configured` error so the UI shows
# a clear message instead of stalling.
GPU_WORKER_BASE_URL=
GPU_WORKER_TOKEN=

# Redis (Upstash) for job/progress state and rate limiting.
# REQUIRED in any multi-container deployment (Netlify, Vercel, etc.).
# Without it, sync handlers, background functions, and pollers each get
# their own in-memory Map — writes from runRender-background never reach
# the polling getJobStatus, and every render stalls at "98% — <jobId>".
# Local single-process dev (vite + a single functions emulator) works
# without Redis, but Netlify builds set NETLIFY=true and the job store
# refuses to start without these.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Edge security — HMAC-signs every API call from the SPA. Without it,
# requests are accepted without auth (dev-only).
EDGE_HMAC_SECRET=

# === OPTIONAL ===

# AI provider (OpenAI) — enables GPT-4o highlight classification.
# When set in the Modal secret `hoops-hype-studio`, the worker uses
# `_classify_action_openai` and falls back to YOLO+heuristic on any error.
OPENAI_API_KEY=

# Music provider (Pixabay) — get a free key at pixabay.com/api/docs
MUSIC_API_KEY=
MUSIC_API_BASE_URL=https://pixabay.com/api

# Observability
LOGTAIL_TOKEN=
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_TOKENS=120
RATE_LIMIT_WINDOW_SEC=60

# Retention policy (days)
RETENTION_DAYS=7

WEB_ORIGIN=http://localhost:5173
